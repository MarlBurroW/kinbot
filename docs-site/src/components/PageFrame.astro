---
import Default from '@astrojs/starlight/components/PageFrame.astro';
---

<Default>
	<slot name="header" slot="header" />
	<slot name="sidebar" slot="sidebar" />
	<slot />
</Default>

<style is:global>
	/* Third orb — mid-page, right-center area */
	.page::before {
		content: '';
		position: fixed;
		width: 500px;
		height: 500px;
		top: 50%;
		left: 60%;
		transform: translate(-50%, -50%);
		border-radius: 50%;
		background: radial-gradient(
			circle,
			oklch(0.76 0.16 15 / 0.04) 0%,
			transparent 70%
		);
		filter: blur(80px);
		pointer-events: none;
		z-index: -1;
	}

	:root[data-theme='light'] .page::before {
		background: radial-gradient(
			circle,
			oklch(0.72 0.16 15 / 0.03) 0%,
			transparent 70%
		);
	}

	/* Sidebar border: use gradient instead of solid */
	@media (min-width: 50rem) {
		[data-has-sidebar] .sidebar-pane {
			border-inline-end: 1px solid oklch(0.60 0.22 300 / 0.10) !important;
		}
	}
</style>
